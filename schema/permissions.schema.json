{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auth.service.ab0t.com/schemas/permissions/v2",
  "title": "Service Permissions Schema",
  "description": "Defines a service's permission surface: actions, resources, permission IDs, roles, and default grants. Used by 01-register-service-permissions.sh to register the service with the Auth Mesh.",
  "type": "object",
  "required": ["service", "registration", "permissions", "roles"],
  "additionalProperties": true,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional JSON Schema reference"
    },
    "service": {
      "type": "object",
      "description": "Service identity metadata",
      "required": ["id", "name", "description"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Unique service identifier. Used as org slug and permission prefix. Lowercase alphanumeric with hyphens.",
          "examples": ["integration", "billing", "resource"]
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable service name",
          "examples": ["Integration Service"]
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "What this service does"
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semver version of the permission schema"
        },
        "audience": {
          "type": "string",
          "description": "Token audience identifier. Used in JWT aud claim for service-to-service auth.",
          "examples": ["integration-service"]
        },
        "maintainer": {
          "type": "string",
          "format": "email",
          "description": "Contact email for the service owner"
        }
      },
      "additionalProperties": false
    },
    "registration": {
      "type": "object",
      "description": "Permission registration config sent to POST /permissions/registry/register",
      "required": ["service", "actions", "resources"],
      "properties": {
        "service": {
          "type": "string",
          "description": "Service name for the registry. Usually matches service.id."
        },
        "actions": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z_]+$" },
          "minItems": 1,
          "description": "Available actions (read, write, create, delete, execute, admin, etc.)",
          "examples": [["read", "write", "create", "delete", "execute", "admin"]]
        },
        "resources": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z_]+$" },
          "minItems": 1,
          "description": "Available resources (services, connections, tools, etc.)",
          "examples": [["services", "connections", "proxy", "tools"]]
        }
      },
      "additionalProperties": false
    },
    "permissions": {
      "type": "array",
      "minItems": 1,
      "description": "All permission IDs this service defines",
      "items": {
        "type": "object",
        "required": ["id", "name", "description", "default_grant"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)?$",
            "description": "Permission ID in {service}.{action}.{resource} or {service}.{action} format",
            "examples": ["integration.read.services", "integration.admin"]
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable permission name"
          },
          "description": {
            "type": "string",
            "minLength": 1,
            "description": "What this permission allows"
          },
          "intent": {
            "type": "string",
            "description": "Why a user would need this permission"
          },
          "risk_level": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"],
            "description": "Risk assessment for granting this permission"
          },
          "cost_impact": {
            "type": "boolean",
            "description": "Whether this permission can trigger billable operations"
          },
          "default_grant": {
            "type": "boolean",
            "description": "Whether this permission is granted to all new users by default"
          },
          "security_notes": {
            "type": "string",
            "description": "Security considerations for this permission"
          },
          "implies": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Permission IDs this permission implies (admin permissions typically imply all others)"
          }
        },
        "additionalProperties": false
      }
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "description": "Pre-defined role bundles mapping to permission sets",
      "items": {
        "type": "object",
        "required": ["id", "name", "permissions"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$",
            "description": "Role identifier",
            "examples": ["integration-user", "integration-admin"]
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "permissions": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "Permission IDs this role grants"
          },
          "default": {
            "type": "boolean",
            "description": "Whether this is the default role for new users. Exactly one role should be default."
          }
        },
        "additionalProperties": false
      }
    },
    "multi_tenancy": {
      "type": "object",
      "description": "Multi-tenancy isolation configuration",
      "properties": {
        "isolation_model": {
          "type": "string",
          "enum": ["organization", "team", "user"],
          "description": "How tenant isolation is enforced"
        },
        "tenant_field": {
          "type": "string",
          "description": "Field name used for tenant scoping (usually org_id)"
        },
        "enforcement": {
          "type": "string",
          "enum": ["strict", "permissive"],
          "description": "Whether cross-tenant access is structurally blocked or permission-gated"
        },
        "cross_tenant_permission": {
          "type": "string",
          "description": "Permission required for cross-tenant access"
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "end_users": {
      "type": "object",
      "description": "Configuration for how end-users are provisioned",
      "properties": {
        "auto_provision": {
          "type": "boolean",
          "description": "Whether users are auto-provisioned on org join"
        },
        "default_role": {
          "type": "string",
          "description": "Role assigned to new end-users"
        },
        "default_team_name": {
          "type": "string",
          "description": "Name of the default team created for end-users (team-inherited model)"
        },
        "provision_on": {
          "type": "string",
          "enum": ["org_join", "first_login", "invite_accept"],
          "description": "When user provisioning occurs"
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "api_key": {
      "type": "object",
      "description": "API key configuration for service-to-service auth",
      "properties": {
        "additional_permissions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Extra permissions needed on the API key beyond service permissions"
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
