{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auth.service.ab0t.com/schemas/credentials-oauth-client/v1",
  "title": "OAuth Client Credentials (output)",
  "description": "Output of 02-register-oauth-client.sh. Contains the registered OAuth client details including client_id and management token. Saved to credentials/oauth-client.json. Follows RFC 7591/7592.",
  "type": "object",
  "required": ["client_id", "redirect_uris", "org_id"],
  "properties": {
    "client_id": {
      "type": "string",
      "description": "OAuth client identifier. Use this in frontend SDK initialization.",
      "examples": ["client_SOSmAPA7xqLnX2Esrg_e-g"]
    },
    "client_secret": {
      "type": ["string", "null"],
      "description": "Client secret. Null for public clients (PKCE)."
    },
    "client_name": {
      "type": "string",
      "description": "Human-readable client name"
    },
    "client_uri": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "Client homepage URL"
    },
    "logo_uri": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "Client logo URL"
    },
    "redirect_uris": {
      "type": "array",
      "items": { "type": "string", "format": "uri" },
      "minItems": 1,
      "description": "Registered redirect URIs"
    },
    "response_types": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Supported response types"
    },
    "grant_types": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Supported grant types"
    },
    "token_endpoint_auth_method": {
      "type": "string",
      "description": "Client authentication method at token endpoint"
    },
    "scope": {
      "type": "string",
      "description": "Registered OAuth scopes"
    },
    "contacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tos_uri": {
      "type": ["string", "null"],
      "description": "Terms of service URL"
    },
    "policy_uri": {
      "type": ["string", "null"],
      "description": "Privacy policy URL"
    },
    "software_id": {
      "type": ["string", "null"],
      "description": "Software identifier (RFC 7591)"
    },
    "software_version": {
      "type": ["string", "null"],
      "description": "Software version"
    },
    "org_id": {
      "type": "string",
      "format": "uuid",
      "description": "Organization this client is registered under"
    },
    "registration_access_token": {
      "type": "string",
      "description": "RFC 7592 management token. Required for updating client config without re-auth."
    },
    "registration_client_uri": {
      "type": "string",
      "format": "uri",
      "description": "RFC 7592 management endpoint for this client"
    },
    "client_id_issued_at": {
      "type": "integer",
      "description": "Unix timestamp of client registration"
    },
    "client_secret_expires_at": {
      "type": "integer",
      "description": "Unix timestamp of client secret expiry. 0 = never."
    },
    "_meta": {
      "type": "object",
      "description": "Setup metadata (not part of OAuth spec)",
      "properties": {
        "org_slug": { "type": "string" },
        "org_id": { "type": "string", "format": "uuid" },
        "auth_service_url": { "type": "string", "format": "uri" },
        "source_config": { "type": "string" },
        "registered_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
