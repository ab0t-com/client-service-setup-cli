{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auth.service.ab0t.com/schemas/credentials-hosted-login/v1",
  "title": "Hosted Login Credentials (output)",
  "description": "Output of 03-setup-hosted-login.sh. Contains the applied login config, hosted login URL, and verification results. Saved to credentials/hosted-login.json.",
  "type": "object",
  "required": ["org_id", "org_slug", "hosted_login_url"],
  "properties": {
    "org_id": {
      "type": "string",
      "format": "uuid",
      "description": "Organization this login config was applied to"
    },
    "org_slug": {
      "type": "string",
      "description": "Organization slug"
    },
    "hosted_login_url": {
      "type": "string",
      "format": "uri",
      "description": "URL for the hosted login page",
      "examples": ["https://auth.service.ab0t.com/login/integration"]
    },
    "public_config_url": {
      "type": "string",
      "format": "uri",
      "description": "Public endpoint for login config (branding, auth methods) — no auth required"
    },
    "applied_config": {
      "description": "The login config that was applied. Same shape as hosted-login.json input.",
      "type": "object",
      "properties": {
        "branding": { "type": "object" },
        "content": { "type": "object" },
        "auth_methods": { "type": "object" },
        "registration": { "type": "object" },
        "security": { "type": "object" }
      },
      "additionalProperties": false
    },
    "verification": {
      "type": "object",
      "description": "HTTP status codes from verification checks",
      "properties": {
        "hosted_login_page": {
          "type": "integer",
          "description": "HTTP status of GET /login/{slug}"
        },
        "public_config": {
          "type": "integer",
          "description": "HTTP status of GET /organizations/{slug}/login-config/public"
        },
        "auth_providers": {
          "type": "integer",
          "description": "HTTP status of GET /organizations/{slug}/auth/providers"
        }
      },
      "additionalProperties": false
    },
    "_meta": {
      "type": "object",
      "description": "Setup metadata",
      "properties": {
        "auth_service_url": { "type": "string", "format": "uri" },
        "source_config": { "type": "string" },
        "applied_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
