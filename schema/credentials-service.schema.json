{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auth.service.ab0t.com/schemas/credentials-service/v1",
  "title": "Service Credentials (output)",
  "description": "Output of 01-register-service-permissions.sh. Contains the service org, admin account, and API key. Saved to credentials/{service_id}.json or credentials/{service_id}-dev.json.",
  "type": "object",
  "required": ["service", "organization", "admin", "api_key"],
  "properties": {
    "service": {
      "type": "string",
      "description": "Service identifier (matches permissions.json service.id)",
      "examples": ["integration"]
    },
    "service_audience": {
      "type": "string",
      "description": "Token audience (matches permissions.json service.audience)",
      "examples": ["integration-service"]
    },
    "auth": {
      "type": "object",
      "description": "Auth context for token validation",
      "properties": {
        "audience": {
          "type": "string",
          "description": "JWT audience claim value. Format: LOCAL:{org_id} for local deployments.",
          "examples": ["LOCAL:83f9767f-d82f-4bf2-9a6c-8698068159a8"]
        }
      },
      "additionalProperties": false
    },
    "organization": {
      "type": "object",
      "description": "Service org created during registration",
      "required": ["id", "slug"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Organization UUID"
        },
        "name": {
          "type": "string",
          "description": "Organization display name"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$",
          "description": "Organization URL slug"
        }
      },
      "additionalProperties": false
    },
    "admin": {
      "type": "object",
      "description": "Admin user account for this service",
      "required": ["email", "password", "user_id"],
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "Admin email address"
        },
        "password": {
          "type": "string",
          "minLength": 8,
          "description": "Admin password (store securely)"
        },
        "user_id": {
          "type": "string",
          "format": "uuid",
          "description": "Admin user UUID"
        },
        "access_token": {
          "type": "string",
          "description": "JWT access token (short-lived, may be expired)"
        },
        "refresh_token": {
          "type": "string",
          "description": "JWT refresh token (long-lived)"
        }
      },
      "additionalProperties": false
    },
    "api_key": {
      "type": "object",
      "description": "API key for service-to-service authentication",
      "required": ["id", "key"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "API key UUID"
        },
        "key": {
          "type": "string",
          "pattern": "^ab0t_sk_",
          "description": "API key value. Prefix: ab0t_sk_live_ (production) or ab0t_sk_test_ (dev)."
        }
      },
      "additionalProperties": false
    },
    "permissions_source": {
      "type": "string",
      "description": "Path to the permissions.json used during registration"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of credential creation"
    }
  },
  "additionalProperties": false
}
