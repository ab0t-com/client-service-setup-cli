{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auth.service.ab0t.com/schemas/credentials-end-users-org/v1",
  "title": "End-Users Org Credentials (output)",
  "description": "Output of 04-setup-default-team.sh or 09-setup-end-users-org-inherited.sh. Contains the child org details, permission model, and hosted login URL. Saved to credentials/end-users-org.json.",
  "type": "object",
  "required": ["org_id", "org_slug", "parent_org_id", "hosted_login_url", "permission_model", "default_permissions"],
  "properties": {
    "org_id": {
      "type": "string",
      "format": "uuid",
      "description": "End-users organization UUID"
    },
    "org_slug": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "End-users org slug (typically {service_id}-users)"
    },
    "org_name": {
      "type": "string",
      "description": "End-users org display name"
    },
    "parent_org_id": {
      "type": "string",
      "format": "uuid",
      "description": "Parent service org UUID. The Zanzibar parent relationship is auto-created."
    },
    "parent_org_slug": {
      "type": "string",
      "description": "Parent service org slug"
    },
    "default_role": {
      "type": "string",
      "description": "Role assigned to new users on registration",
      "examples": ["member", "end_user"]
    },
    "default_team_id": {
      "type": "string",
      "format": "uuid",
      "description": "Default team UUID (team-inherited model only)"
    },
    "default_team_name": {
      "type": "string",
      "description": "Default team name (team-inherited model only)",
      "examples": ["Default Users"]
    },
    "oauth_client_id": {
      "type": "string",
      "description": "OAuth client registered on the end-users org"
    },
    "hosted_login_url": {
      "type": "string",
      "format": "uri",
      "description": "URL for the hosted login page. Give this to your frontend.",
      "examples": ["https://auth.service.ab0t.com/login/integration-users"]
    },
    "default_permissions": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "description": "Permissions automatically granted to new users via the chosen permission model"
    },
    "permission_model": {
      "type": "string",
      "enum": ["team-inherited", "org-inherited"],
      "description": "How permissions flow to users. team-inherited: via default team membership. org-inherited: via org membership + Zanzibar."
    },
    "_meta": {
      "type": "object",
      "description": "Setup metadata",
      "properties": {
        "auth_service_url": { "type": "string", "format": "uri" },
        "created_at": { "type": "string", "format": "date-time" },
        "script": { "type": "string", "description": "Which setup script created this" },
        "note": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
