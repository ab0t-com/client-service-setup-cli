# Service-specific config — only .example files are committed
config/permissions.json
config/hosted-login.json
config/oauth-client.json

# Credentials — real secrets live in credentials/*.json (blocked by credentials/.gitignore)
*.env
*.env.*
!*.env.example
.env.local

# OS / editor
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace

# Logs
*.log
logs/

# Temp files
*.tmp
*.bak
*.bak.*

# Node (if SDK tooling is added later)
node_modules/
package-lock.json

# Python
__pycache__/
*.pyc
.venv/
