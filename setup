#!/bin/bash
# Auth Mesh Client Setup CLI
#
# Interactive CLI for setting up a service with the Auth Mesh platform.
# Guides you through all setup steps or runs individual commands.
#
# Usage:
#   ./setup                     Interactive menu
#   ./setup run                 Run all steps in order
#   ./setup run 01              Run a specific step
#   ./setup status              Show current setup status
#   ./setup verify              Verify everything is working
#   ./setup help                Show this help
#
# Environment:
#   AUTH_SERVICE_URL   - Auth service URL (default: https://auth.service.ab0t.com)
#   DRY_RUN            - Set to 1 to preview without making changes

set -euo pipefail

SETUP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export SETUP_DIR
export AUTH_SERVICE_URL="${AUTH_SERVICE_URL:-https://auth.service.ab0t.com}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ── Script registry ──
STEPS=(
  "01:register-service-permissions:Register service org, permissions, and API key"
  "02:register-oauth-client:Register OAuth client for frontend"
  "03:setup-hosted-login:Configure hosted login page"
  "04:setup-default-team:Create end-users org with default team (permissions via team membership)"
  "05:verify-setup:Verify everything is working"
  "06:test-end-user:End-to-end test: register user, verify team + permissions"
)

# ── Helpers ──

step_script() {
  local num="$1"
  for entry in "${STEPS[@]}"; do
    local n="${entry%%:*}"
    if [ "$n" = "$num" ]; then
      local rest="${entry#*:}"
      local name="${rest%%:*}"
      echo "$SETUP_DIR/scripts/${num}-${name}.sh"
      return
    fi
  done
  echo ""
}

step_desc() {
  local num="$1"
  for entry in "${STEPS[@]}"; do
    local n="${entry%%:*}"
    if [ "$n" = "$num" ]; then
      echo "${entry##*:}"
      return
    fi
  done
}

step_status() {
  local num="$1"
  case "$num" in
    01)
      local svc_id
      svc_id="$(jq -r '.service.id // "integration"' "$SETUP_DIR/config/permissions.json" 2>/dev/null || echo "integration")"
      if ls "$SETUP_DIR/credentials/${svc_id}"*.json "$SETUP_DIR/credentials/integration-service"*.json 2>/dev/null | head -1 | grep -q .; then
        echo "done"
      else
        echo "pending"
      fi
      ;;
    02)
      if ls "$SETUP_DIR/credentials/oauth-client"*.json 2>/dev/null | head -1 | grep -q .; then
        echo "done"
      else
        echo "pending"
      fi
      ;;
    03)
      if ls "$SETUP_DIR/credentials/hosted-login"*.json 2>/dev/null | head -1 | grep -q .; then
        echo "done"
      else
        echo "pending"
      fi
      ;;
    04)
      if ls "$SETUP_DIR/credentials/end-users-org"*.json 2>/dev/null | head -1 | grep -q .; then
        echo "done"
      else
        echo "pending"
      fi
      ;;
    05) echo "run-anytime" ;;
    06) echo "run-anytime" ;;
    *)  echo "unknown" ;;
  esac
}

status_icon() {
  case "$1" in
    done)         echo -e "${GREEN}done${NC}" ;;
    pending)      echo -e "${YELLOW}pending${NC}" ;;
    run-anytime)  echo -e "${DIM}run anytime${NC}" ;;
    *)            echo -e "${RED}?${NC}" ;;
  esac
}

print_header() {
  echo ""
  echo -e "${MAGENTA}${BOLD}"
  echo "    _         _   _       __  __           _     "
  echo "   / \  _   _| |_| |__   |  \/  | ___  ___| |__  "
  echo "  / _ \| | | | __| '_ \  | |\/| |/ _ \/ __| '_ \ "
  echo " / ___ \ |_| | |_| | | | | |  | |  __/\__ \ | | |"
  echo "/_/   \_\__,_|\__|_| |_| |_|  |_|\___||___/_| |_|"
  echo -e "${NC}"
  echo -e "${CYAN}  Client Setup CLI${NC}"
  echo -e "${DIM}  Auth Service: $AUTH_SERVICE_URL${NC}"
  echo ""
}

print_steps() {
  echo -e "${BOLD}Setup Steps:${NC}"
  echo ""
  for entry in "${STEPS[@]}"; do
    local num="${entry%%:*}"
    local rest="${entry#*:}"
    local name="${rest%%:*}"
    local desc="${rest#*:}"
    local status
    status="$(step_status "$num")"
    local icon
    icon="$(status_icon "$status")"
    echo -e "  ${BOLD}$num${NC}  $desc  [$icon]"
  done
  echo ""
}

# ── Commands ──

cmd_help() {
  echo -e "${BOLD}Usage:${NC}"
  echo "  ./setup                     Interactive menu"
  echo "  ./setup run                 Run all pending steps in order"
  echo "  ./setup run <step>          Run a specific step (01-05)"
  echo "  ./setup status              Show current setup status"
  echo "  ./setup verify              Run verification checks"
  echo "  ./setup dry-run             Preview all steps without changes"
  echo "  ./setup help                Show this help"
  echo ""
  echo -e "${BOLD}Steps:${NC}"
  for entry in "${STEPS[@]}"; do
    local num="${entry%%:*}"
    local desc="${entry##*:}"
    echo "  $num  $desc"
  done
  echo ""
  echo -e "${BOLD}Environment:${NC}"
  echo "  AUTH_SERVICE_URL   Auth service URL (current: $AUTH_SERVICE_URL)"
  echo "  DRY_RUN            Set to 1 for dry run mode"
  echo ""
  echo -e "${BOLD}Config files to edit:${NC}"
  echo "  config/permissions.json    Service permissions and roles"
  echo "  config/oauth-client.json   OAuth client redirect URIs"
  echo "  config/hosted-login.json   Login page branding and settings"
  echo ""
}

cmd_status() {
  print_header
  print_steps

  # Show config summary
  if [ -f "$SETUP_DIR/config/permissions.json" ]; then
    local svc_id svc_name perm_count
    svc_id="$(jq -r '.service.id // "?"' "$SETUP_DIR/config/permissions.json")"
    svc_name="$(jq -r '.service.name // "?"' "$SETUP_DIR/config/permissions.json")"
    perm_count="$(jq '.permissions | length' "$SETUP_DIR/config/permissions.json")"
    echo -e "${BOLD}Service:${NC} $svc_name ($svc_id)"
    echo -e "${BOLD}Permissions:${NC} $perm_count defined"
  fi

  # Show credentials
  if ls "$SETUP_DIR/credentials/"*.json 2>/dev/null | grep -v .gitignore | head -1 | grep -q . 2>/dev/null; then
    echo ""
    echo -e "${BOLD}Credentials:${NC}"
    for f in "$SETUP_DIR/credentials/"*.json; do
      [ -f "$f" ] || continue
      echo -e "  ${DIM}$(basename "$f")${NC}"
    done
  fi
  echo ""
}

cmd_run_step() {
  local step_num="$1"
  # Zero-pad if needed
  step_num="$(printf "%02d" "$step_num" 2>/dev/null || echo "$step_num")"

  local script
  script="$(step_script "$step_num")"

  if [ -z "$script" ] || [ ! -f "$script" ]; then
    echo -e "${RED}Unknown step: $step_num${NC}"
    echo "Available steps: 01-06"
    exit 1
  fi

  local desc
  desc="$(step_desc "$step_num")"
  echo ""
  echo -e "${MAGENTA}${BOLD}Step $step_num: $desc${NC}"
  echo -e "${DIM}$(basename "$script")${NC}"
  echo ""

  chmod +x "$script"
  exec bash "$script"
}

cmd_run_all() {
  print_header

  for entry in "${STEPS[@]}"; do
    local num="${entry%%:*}"
    local rest="${entry#*:}"
    local name="${rest%%:*}"
    local desc="${rest#*:}"
    local script="$SETUP_DIR/scripts/${num}-${name}.sh"

    echo ""
    echo -e "${MAGENTA}${BOLD}[$num] $desc${NC}"
    echo -e "${DIM}$(basename "$script")${NC}"
    echo ""

    if [ ! -f "$script" ]; then
      echo -e "  ${RED}Script not found: $script${NC}"
      continue
    fi

    chmod +x "$script"

    if bash "$script"; then
      echo -e "${GREEN}Step $num completed${NC}"
    else
      echo -e "${RED}Step $num failed${NC}"
      echo ""
      echo -e "${YELLOW}Fix the issue above, then re-run:${NC}"
      echo "  ./setup run $num"
      exit 1
    fi
  done

  echo ""
  echo -e "${GREEN}${BOLD}All steps completed successfully.${NC}"
  echo ""
}

cmd_verify() {
  local script="$SETUP_DIR/scripts/05-verify-setup.sh"
  chmod +x "$script"
  exec bash "$script"
}

cmd_dry_run() {
  export DRY_RUN=1
  echo -e "${YELLOW}${BOLD}DRY RUN MODE — no changes will be made${NC}"

  for entry in "${STEPS[@]}"; do
    local num="${entry%%:*}"
    local rest="${entry#*:}"
    local name="${rest%%:*}"
    local desc="${rest#*:}"
    local script="$SETUP_DIR/scripts/${num}-${name}.sh"

    echo ""
    echo -e "${MAGENTA}${BOLD}[$num] $desc${NC}"

    if [ ! -f "$script" ]; then
      echo -e "  ${DIM}Script not found${NC}"
      continue
    fi

    chmod +x "$script"
    bash "$script" || true
  done
}

cmd_interactive() {
  print_header
  print_steps

  echo -e "${BOLD}What would you like to do?${NC}"
  echo ""
  echo "  [a] Run all steps in order"
  echo "  [1-6] Run a specific step"
  echo "  [s] Show status"
  echo "  [v] Verify setup"
  echo "  [d] Dry run (preview all steps)"
  echo "  [q] Quit"
  echo ""
  read -p "Choice: " -r choice

  case "$choice" in
    a|A)    cmd_run_all ;;
    [1-6])  cmd_run_step "$choice" ;;
    s|S)    cmd_status ;;
    v|V)    cmd_verify ;;
    d|D)    cmd_dry_run ;;
    q|Q)    echo "Bye."; exit 0 ;;
    *)      echo -e "${RED}Invalid choice: $choice${NC}"; exit 1 ;;
  esac
}

# ── Main ──

case "${1:-}" in
  run)
    if [ -n "${2:-}" ]; then
      cmd_run_step "$2"
    else
      cmd_run_all
    fi
    ;;
  status)   cmd_status ;;
  verify)   cmd_verify ;;
  dry-run)  cmd_dry_run ;;
  help|-h|--help)  cmd_help ;;
  "")       cmd_interactive ;;
  *)
    # Allow "./setup 01" as shorthand for "./setup run 01"
    if [[ "$1" =~ ^[0-9]+$ ]]; then
      cmd_run_step "$1"
    else
      echo -e "${RED}Unknown command: $1${NC}"
      echo "Run './setup help' for usage."
      exit 1
    fi
    ;;
esac
